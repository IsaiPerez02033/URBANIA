# ==============================================================================
# CONFIGURACION DEL ENTORNO DE SUSVI (BACKEND API)
# Copia este archivo como '.env' para definir tus parametros locales
# ==============================================================================

# ── 1. MODO DE EJECUCION ──────────────────────────────────────────────────────
# SUSVI_PROD_MODE controla si se realizan peticiones reales a IBM Cloud vía
# Watsonx AI o si el sistema opera en modo "demo" (mocks integrados y fallback).
# - '0' o vacio: Modo Demo / Offline / Fallback (No requiere credenciales)
# - '1' o 'true': Modo Produccion (Requiere API Key y Project ID)
SUSVI_PROD_MODE=0


# ── 2. CREDENCIALES IBM WATSONX AI ────────────────────────────────────────────
# Obten estas credenciales de la consola de IBM Cloud.
WATSONX_API_KEY="tu_api_key_de_ibm_cloud_aqui"
WATSONX_PROJECT_ID="tu_project_id_de_watsonx_aqui"

# Watsonx base URL (dependiendo de la region contratada)
WATSONX_URL="https://us-south.ml.cloud.ibm.com"


# ── 3. CONFIGURACIONES AVANZADAS (Opcional) ───────────────────────────────────
# Que modelo utilizar especificamente para el Agente de Negocios (C-Suite).
# Puede requerir llama 3 o granite dependiendo de los modelos desplegados.
WATSONX_MODEL_ID_BUSINESS="meta-llama/llama-3-1-70b-instruct"
